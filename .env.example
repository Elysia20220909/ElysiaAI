OPENAI_API_KEY=xxxx
MODEL=gpt-4.1-mini

# 認証/セキュリティ
AUTH_USERNAME=elysia
AUTH_PASSWORD=elysia-dev-password
JWT_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ALERT_WEBHOOK_URL=

# レート制限/Redis（任意）
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
RATE_LIMIT_RPM=50

# マルチモデルアンサンブル設定（オプション）
SECONDARY_MODEL_ENDPOINT=
SECONDARY_MODEL_API_KEY=
TERTIARY_MODEL_ENDPOINT=
TERTIARY_MODEL_API_KEY=
