{
  "name": "elysia-ai-monorepo",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "dev": "bun --filter \"*\" dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "clean": "powershell -ExecutionPolicy Bypass -File ./scripts/clean.ps1 -Deep",
    "db:init": "bun --filter \"@elysia-ai/server\" db:init",
    "db:migrate": "bun --filter \"@elysia-ai/server\" db:migrate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json}": [
      "biome check --write"
    ],
    "*": [
      "bun run scripts/security-scan.ts"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2"
  }
}
